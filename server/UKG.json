            "description": "Returns last success time and staleness in minutes for each sync job. isStale=true means the job hasn't succeeded in over 30 minutes. With UKG_API_AVAILABLE=false, status will be 'skipped' which is treated as healthy."
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const data = pm.response.json().data;",
              "pm.test('Returns array of job statuses', () => pm.expect(data).to.be.an('array'));",
              "pm.test('Has 4 jobs', () => pm.expect(data.length).to.equal(4));",
              "const jobs = data.map(j => j.jobName);",
              "pm.test('attendance_live_sync present', () => pm.expect(jobs).to.include('attendance_live_sync'));",
              "data.forEach(job => {",
              "  console.log(job.jobName, '→', job.lastStatus, '| stale:', job.isStale, '| minutes:', job.staleMinutes);",
              "});"
            ]}
          }]
