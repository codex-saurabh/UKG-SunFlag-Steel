          "name": "Unknown route (expect 404)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/doesnotexist"
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Unknown = 404', () => pm.response.to.have.status(404));"] }
          }]
        }
      ]
    },
     {
      "name": "08 — Intelligence",
      "item": [
        {
          "name": "Alerts — Active list",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/intelligence/alerts",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "description": "Returns all active alerts. After first run the list will be empty until the consecutive_absence_scan job runs or you trigger it manually."
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Has data array', () => pm.expect(pm.response.json().data).to.be.an('array'));",
              "const alerts = pm.response.json().data;",
              "if (alerts.length > 0) {",
              "  pm.collectionVariables.set('alert_id', alerts[0]._id);",
              "  console.log('alert_id saved:', alerts[0]._id);",
              "}"
            ]}
          }]
        },
        {
          "name": "Alerts — Filter by severity (critical)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/intelligence/alerts?severity=critical",
              "query": [{ "key": "severity", "value": "critical" }]
            },
